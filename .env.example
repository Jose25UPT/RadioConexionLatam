# Copia este archivo a .env y rellena los valores reales
# cp .env.example .env

# PostgreSQL
DB_USER=radio_user
DB_PASSWORD=CAMBIA_ESTO
DB_NAME=radio
DB_HOST=db
DB_PORT=5432

# JWT — genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA

# Admin por defecto (0 en produccion)
AUTO_CREATE_DEFAULT_ADMIN=0

# Fans Choice — MySQL externo
FC_DB_HOST=IP_DEL_SERVIDOR_MYSQL
FC_DB_NAME=fanschoice
FC_DB_USER=USUARIO_MYSQL
FC_DB_PASSWORD=CAMBIA_ESTO

# Google OAuth 2.0 (Fans Choice)
FC_GOOGLE_CLIENT_ID=TU_CLIENT_ID.apps.googleusercontent.com
FC_GOOGLE_CLIENT_SECRET=GOCSPX-TU_SECRET

# Google reCAPTCHA v2
FC_RECAPTCHA_SECRET_KEY=TU_SECRET_KEY
FC_RECAPTCHA_SITE_KEY=TU_SITE_KEY

# Frontend Vite
VITE_SPOTIFY_EMBED=https://open.spotify.com/embed/episode/TU_EPISODE_ID
